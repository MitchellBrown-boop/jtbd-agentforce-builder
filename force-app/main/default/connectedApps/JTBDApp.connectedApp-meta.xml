<?xml version="1.0" encoding="UTF-8"?>
<ConnectedApp xmlns="http://soap.sforce.com/2006/04/metadata">
    <label>JTBD Vercel App</label>
    <contactEmail>trailsignup.1a4a15bf9f4ce3@salesforce.com</contactEmail>
    <description>Connected App for JTBD Interactive Builder web application to enable REST API access for creating and managing JTBD jobs, personas, and agent opportunities</description>

    <oauthConfig>
        <callbackUrl>https://algolia-jtbd.vercel.app/auth/callback</callbackUrl>
        <isAdminApproved>true</isAdminApproved>
        <isConsumerSecretOptional>true</isConsumerSecretOptional>
        <isIntrospectAllTokens>false</isIntrospectAllTokens>

        <!-- Core API Access for REST operations -->
        <scopes>Api</scopes>
        <scopes>RefreshToken</scopes>
        <scopes>Web</scopes>

        <!-- OpenID Connect for user identity -->
        <scopes>OpenID</scopes>
        <scopes>Profile</scopes>
        <scopes>Email</scopes>
    </oauthConfig>

    <oauthPolicy>
        <ipRelaxation>ENFORCE</ipRelaxation>
        <refreshTokenPolicy>infinite</refreshTokenPolicy>
    </oauthPolicy>

    <!-- Session Policy -->
    <sessionPolicy>
        <sessionTimeout>120</sessionTimeout>
    </sessionPolicy>
</ConnectedApp>