# Copy this file to .env.local and add your Google Service Account JSON

# For local development, you can use gcloud auth or set GOOGLE_APPLICATION_CREDENTIALS
# For production (Vercel), set GOOGLE_SERVICE_ACCOUNT_KEY with the full JSON content

# Example:
# GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"your-project",...}

# For local testing, you can also use:
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/your/service-account-key.json